  35:Core/Src/FATFS_SD.c **** /* SPI transmit a byte */
  36:Core/Src/FATFS_SD.c **** static void SPI_TxByte(uint8_t data)
  37:Core/Src/FATFS_SD.c **** {
  38:Core/Src/FATFS_SD.c ****   while(!__HAL_SPI_GET_FLAG(HSPI_SDCARD, SPI_FLAG_TXE));
  39:Core/Src/FATFS_SD.c ****   HAL_SPI_Transmit(HSPI_SDCARD, &data, 1, SPI_TIMEOUT);
  40:Core/Src/FATFS_SD.c **** }
  41:Core/Src/FATFS_SD.c **** 
  42:Core/Src/FATFS_SD.c **** /* SPI transmit buffer */
  43:Core/Src/FATFS_SD.c **** static void SPI_TxBuffer(uint8_t *buffer, uint16_t len)
  44:Core/Src/FATFS_SD.c **** {
  45:Core/Src/FATFS_SD.c ****   while(!__HAL_SPI_GET_FLAG(HSPI_SDCARD, SPI_FLAG_TXE));
  46:Core/Src/FATFS_SD.c ****   HAL_SPI_Transmit(HSPI_SDCARD, buffer, len, SPI_TIMEOUT);
  47:Core/Src/FATFS_SD.c **** }
  48:Core/Src/FATFS_SD.c **** 
  49:Core/Src/FATFS_SD.c **** /* SPI receive a byte */
  50:Core/Src/FATFS_SD.c **** static uint8_t SPI_RxByte(void)
  51:Core/Src/FATFS_SD.c **** {
  52:Core/Src/FATFS_SD.c ****   uint8_t dummy, data;
  53:Core/Src/FATFS_SD.c ****   dummy = 0xFF;
  54:Core/Src/FATFS_SD.c ****   while(!__HAL_SPI_GET_FLAG(HSPI_SDCARD, SPI_FLAG_TXE));
  55:Core/Src/FATFS_SD.c ****   HAL_SPI_TransmitReceive(HSPI_SDCARD, &dummy, &data, 1, SPI_TIMEOUT);
  56:Core/Src/FATFS_SD.c ****   return data;
  57:Core/Src/FATFS_SD.c **** }
  58:Core/Src/FATFS_SD.c **** 
  59:Core/Src/FATFS_SD.c **** /* SPI receive a byte via pointer */
  60:Core/Src/FATFS_SD.c **** static void SPI_RxBytePtr(uint8_t *buff)
  61:Core/Src/FATFS_SD.c **** {
  62:Core/Src/FATFS_SD.c ****   *buff = SPI_RxByte();
  63:Core/Src/FATFS_SD.c **** }
  64:Core/Src/FATFS_SD.c **** 
  65:Core/Src/FATFS_SD.c **** //-----[ SD Card Functions ]-----
  66:Core/Src/FATFS_SD.c **** 
  67:Core/Src/FATFS_SD.c **** /* wait SD ready */
  68:Core/Src/FATFS_SD.c **** static uint8_t SD_ReadyWait(void)
  69:Core/Src/FATFS_SD.c **** {
  70:Core/Src/FATFS_SD.c ****   uint8_t res;
  71:Core/Src/FATFS_SD.c ****   /* timeout 500ms */
  72:Core/Src/FATFS_SD.c ****   Timer2 = 500;
  73:Core/Src/FATFS_SD.c ****   /* if SD goes ready, receives 0xFF */
  74:Core/Src/FATFS_SD.c ****   do {
  75:Core/Src/FATFS_SD.c ****     res = SPI_RxByte();
  76:Core/Src/FATFS_SD.c ****   } while ((res != 0xFF) && Timer2);
  77:Core/Src/FATFS_SD.c ****   return res;
  78:Core/Src/FATFS_SD.c **** }
  79:Core/Src/FATFS_SD.c **** 
  80:Core/Src/FATFS_SD.c **** /* power on */
  81:Core/Src/FATFS_SD.c **** static void SD_PowerOn(void)
  82:Core/Src/FATFS_SD.c **** {
  83:Core/Src/FATFS_SD.c ****   uint8_t args[6];
  84:Core/Src/FATFS_SD.c ****   uint32_t cnt = 0x1FFF;
  85:Core/Src/FATFS_SD.c ****   /* transmit bytes to wake up */
  86:Core/Src/FATFS_SD.c ****   DESELECT();
  87:Core/Src/FATFS_SD.c ****   for(int i = 0; i < 10; i++)
  88:Core/Src/FATFS_SD.c ****   {
ARM GAS  C:\msys64\tmp\ccTTDb5H.s 			page 3


  89:Core/Src/FATFS_SD.c ****     SPI_TxByte(0xFF);
  90:Core/Src/FATFS_SD.c ****   }
  91:Core/Src/FATFS_SD.c ****   /* slave select */
  92:Core/Src/FATFS_SD.c ****   SELECT();
  93:Core/Src/FATFS_SD.c ****   /* make idle state */
  94:Core/Src/FATFS_SD.c ****   args[0] = CMD0;   /* CMD0:GO_IDLE_STATE */
  95:Core/Src/FATFS_SD.c ****   args[1] = 0;
  96:Core/Src/FATFS_SD.c ****   args[2] = 0;
  97:Core/Src/FATFS_SD.c ****   args[3] = 0;
  98:Core/Src/FATFS_SD.c ****   args[4] = 0;
  99:Core/Src/FATFS_SD.c ****   args[5] = 0x95;
 100:Core/Src/FATFS_SD.c ****   SPI_TxBuffer(args, sizeof(args));
 101:Core/Src/FATFS_SD.c ****   /* wait response */
 102:Core/Src/FATFS_SD.c ****   while ((SPI_RxByte() != 0x01) && cnt)
 103:Core/Src/FATFS_SD.c ****   {
 104:Core/Src/FATFS_SD.c ****     cnt--;
 105:Core/Src/FATFS_SD.c ****   }
 106:Core/Src/FATFS_SD.c ****   DESELECT();
 107:Core/Src/FATFS_SD.c ****   SPI_TxByte(0XFF);
 108:Core/Src/FATFS_SD.c ****   PowerFlag = 1;
 109:Core/Src/FATFS_SD.c **** }
