  10:Core/Src/FATFS_SD.c **** #include "FATFS_SD.h"
  11:Core/Src/FATFS_SD.c **** 
  12:Core/Src/FATFS_SD.c **** #define TRUE  1
  13:Core/Src/FATFS_SD.c **** #define FALSE 0
  14:Core/Src/FATFS_SD.c **** #define bool BYTE
  15:Core/Src/FATFS_SD.c **** 
  16:Core/Src/FATFS_SD.c **** static volatile DSTATUS Stat = STA_NOINIT;  /* Disk Status */
  17:Core/Src/FATFS_SD.c **** uint16_t Timer1, Timer2; 		/* 1ms Timer Counters */
  18:Core/Src/FATFS_SD.c **** static uint8_t CardType; 		/* Type 0:MMC, 1:SDC, 2:Block addressing */
  19:Core/Src/FATFS_SD.c **** static uint8_t PowerFlag = 0;	/* Power flag */
  20:Core/Src/FATFS_SD.c **** 
