 145:Core/Src/FATFS_SD.c **** /* transmit data block */
 146:Core/Src/FATFS_SD.c **** #if _USE_WRITE == 1
 147:Core/Src/FATFS_SD.c **** static bool SD_TxDataBlock(const uint8_t *buff, BYTE token)
 148:Core/Src/FATFS_SD.c **** {
 149:Core/Src/FATFS_SD.c ****   uint8_t resp;
 150:Core/Src/FATFS_SD.c ****   uint8_t i = 0;
 151:Core/Src/FATFS_SD.c ****   /* wait SD ready */
 152:Core/Src/FATFS_SD.c ****   if (SD_ReadyWait() != 0xFF) return FALSE;
 153:Core/Src/FATFS_SD.c ****   /* transmit token */
 154:Core/Src/FATFS_SD.c ****   SPI_TxByte(token);
 155:Core/Src/FATFS_SD.c ****   /* if it's not STOP token, transmit data */
 156:Core/Src/FATFS_SD.c ****   if (token != 0xFD)
 157:Core/Src/FATFS_SD.c ****   {
 158:Core/Src/FATFS_SD.c ****     SPI_TxBuffer((uint8_t*)buff, 512);
 159:Core/Src/FATFS_SD.c ****     /* discard CRC */
 160:Core/Src/FATFS_SD.c ****     SPI_RxByte();
 161:Core/Src/FATFS_SD.c ****     SPI_RxByte();
 162:Core/Src/FATFS_SD.c ****     /* receive response */
 163:Core/Src/FATFS_SD.c ****     while (i <= 64)
 164:Core/Src/FATFS_SD.c ****     {
 165:Core/Src/FATFS_SD.c ****       resp = SPI_RxByte();
 166:Core/Src/FATFS_SD.c ****       /* transmit 0x05 accepted */
 167:Core/Src/FATFS_SD.c ****       if ((resp & 0x1F) == 0x05) break;
 168:Core/Src/FATFS_SD.c ****       i++;
 169:Core/Src/FATFS_SD.c ****     }
 170:Core/Src/FATFS_SD.c ****     /* recv buffer clear */
 171:Core/Src/FATFS_SD.c ****     while (SPI_RxByte() == 0);
 172:Core/Src/FATFS_SD.c ****   }
 173:Core/Src/FATFS_SD.c ****   /* transmit 0x05 accepted */
 174:Core/Src/FATFS_SD.c ****   if ((resp & 0x1F) == 0x05) return TRUE;
 175:Core/Src/FATFS_SD.c **** 
 176:Core/Src/FATFS_SD.c ****   return FALSE;
 177:Core/Src/FATFS_SD.c **** }
 178:Core/Src/FATFS_SD.c **** #endif /* _USE_WRITE */
