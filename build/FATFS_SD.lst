 241:Core/Src/FATFS_SD.c ****         /* ACMD41 with HCS bit */
 242:Core/Src/FATFS_SD.c ****         do {
 243:Core/Src/FATFS_SD.c ****           if (SD_SendCmd(CMD55, 0) <= 1 && SD_SendCmd(CMD41, 1UL << 30) == 0) break;
 244:Core/Src/FATFS_SD.c ****         } while (Timer1);
 245:Core/Src/FATFS_SD.c **** 
 246:Core/Src/FATFS_SD.c ****         /* READ_OCR */
 247:Core/Src/FATFS_SD.c ****         if (Timer1 && SD_SendCmd(CMD58, 0) == 0)
 248:Core/Src/FATFS_SD.c ****         {
 249:Core/Src/FATFS_SD.c ****           /* Check CCS bit */
 250:Core/Src/FATFS_SD.c ****           for (n = 0; n < 4; n++)
 251:Core/Src/FATFS_SD.c ****           {
 252:Core/Src/FATFS_SD.c ****             ocr[n] = SPI_RxByte();
 253:Core/Src/FATFS_SD.c ****           }
 254:Core/Src/FATFS_SD.c **** 
 255:Core/Src/FATFS_SD.c ****           /* SDv2 (HC or SC) */
 256:Core/Src/FATFS_SD.c ****           type = (ocr[0] & 0x40) ? CT_SD2 | CT_BLOCK : CT_SD2;
 257:Core/Src/FATFS_SD.c ****         }
 258:Core/Src/FATFS_SD.c ****       }
 259:Core/Src/FATFS_SD.c ****     }
 260:Core/Src/FATFS_SD.c ****     else
 261:Core/Src/FATFS_SD.c ****     {
 262:Core/Src/FATFS_SD.c ****       /* SDC V1 or MMC */
 263:Core/Src/FATFS_SD.c ****       type = (SD_SendCmd(CMD55, 0) <= 1 && SD_SendCmd(CMD41, 0) <= 1) ? CT_SD1 : CT_MMC;
 264:Core/Src/FATFS_SD.c ****       do
 265:Core/Src/FATFS_SD.c ****       {
 266:Core/Src/FATFS_SD.c ****         if (type == CT_SD1)
 267:Core/Src/FATFS_SD.c ****         {
 268:Core/Src/FATFS_SD.c ****           if (SD_SendCmd(CMD55, 0) <= 1 && SD_SendCmd(CMD41, 0) == 0) break; /* ACMD41 */
 269:Core/Src/FATFS_SD.c ****         }
 270:Core/Src/FATFS_SD.c ****         else
 271:Core/Src/FATFS_SD.c ****         {
 272:Core/Src/FATFS_SD.c ****           if (SD_SendCmd(CMD1, 0) == 0) break; /* CMD1 */
 273:Core/Src/FATFS_SD.c ****         }
 274:Core/Src/FATFS_SD.c ****       } while (Timer1);
 275:Core/Src/FATFS_SD.c ****       /* SET_BLOCKLEN */
 276:Core/Src/FATFS_SD.c ****       if (!Timer1 || SD_SendCmd(CMD16, 512) != 0) type = 0;
 277:Core/Src/FATFS_SD.c ****     }
 278:Core/Src/FATFS_SD.c ****   }
 279:Core/Src/FATFS_SD.c ****   CardType = type;
 280:Core/Src/FATFS_SD.c ****   /* Idle */
 281:Core/Src/FATFS_SD.c ****   DESELECT();
 282:Core/Src/FATFS_SD.c ****   SPI_RxByte();
 283:Core/Src/FATFS_SD.c ****   /* Clear STA_NOINIT */
ARM GAS  C:\msys64\tmp\ccTTDb5H.s 			page 24


 284:Core/Src/FATFS_SD.c ****   if (type)
 285:Core/Src/FATFS_SD.c ****   {
 286:Core/Src/FATFS_SD.c ****     Stat &= ~STA_NOINIT;
 287:Core/Src/FATFS_SD.c ****   }
 288:Core/Src/FATFS_SD.c ****   else
 289:Core/Src/FATFS_SD.c ****   {
 290:Core/Src/FATFS_SD.c ****     /* Initialization failed */
 291:Core/Src/FATFS_SD.c ****     SD_PowerOff();
 292:Core/Src/FATFS_SD.c ****   }
 293:Core/Src/FATFS_SD.c ****   return Stat;
 294:Core/Src/FATFS_SD.c **** }
