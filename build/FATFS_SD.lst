 123:Core/Src/FATFS_SD.c **** /* receive data block */
 124:Core/Src/FATFS_SD.c **** static bool SD_RxDataBlock(BYTE *buff, UINT len)
 125:Core/Src/FATFS_SD.c **** {
 126:Core/Src/FATFS_SD.c ****   uint8_t token;
 127:Core/Src/FATFS_SD.c ****   /* timeout 200ms */
 128:Core/Src/FATFS_SD.c ****   Timer1 = 200;
 129:Core/Src/FATFS_SD.c ****   /* loop until receive a response or timeout */
 130:Core/Src/FATFS_SD.c ****   do {
 131:Core/Src/FATFS_SD.c ****     token = SPI_RxByte();
 132:Core/Src/FATFS_SD.c ****   } while((token == 0xFF) && Timer1);
 133:Core/Src/FATFS_SD.c ****   /* invalid response */
 134:Core/Src/FATFS_SD.c ****   if(token != 0xFE) return FALSE;
 135:Core/Src/FATFS_SD.c ****   /* receive data */
 136:Core/Src/FATFS_SD.c ****   do {
 137:Core/Src/FATFS_SD.c ****     SPI_RxBytePtr(buff++);
 138:Core/Src/FATFS_SD.c ****   } while(len--);
 139:Core/Src/FATFS_SD.c ****   /* discard CRC */
 140:Core/Src/FATFS_SD.c ****   SPI_RxByte();
 141:Core/Src/FATFS_SD.c ****   SPI_RxByte();
